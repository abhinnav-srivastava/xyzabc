  "common_columns": {
    "checklist_id": {
      "name": "Checklist-ID",
      "required": true,
      "type": "text",
      "auto_generated": true,
      "description": "Auto-assigned checklist ID based on role",
      "validation": {
        "pattern": "^[A-Z]{2,4}-\\d{3,4}$"
      }
    },
    "sr_no": {
      "name": "SrNo",
      "required": true,
      "type": "integer",
      "description": "Serial number from Excel",
      "validation": {
        "min_value": 1,
        "max_value": 9999
      }
    },
    "category": {
      "name": "Category",
      "required": true,
      "type": "text",
      "description": "Main category of the checklist item",
      "validation": {
        "min_length": 1,
        "max_length": 100,
        "pattern": "^[a-zA-Z0-9\\s\\-_]+$"
      }
    },
    "sub_category": {
      "name": "SubCategory",
      "required": true,
      "type": "text",
      "description": "Specific subcategory or item name",
      "validation": {
        "min_length": 1,
        "max_length": 200,
        "pattern": "^[a-zA-Z0-9\\s\\-_]+$"
      }
    },
    "description": {
      "name": "Description",
      "required": true,
      "type": "text",
      "description": "Detailed description of the checklist item",
      "validation": {
        "min_length": 10,
        "max_length": 1000
      }
    },
    "how_to_measure": {
      "name": "How to Measure",
      "required": false,
      "type": "text",
      "description": "How to verify or measure compliance",
      "validation": {
        "max_length": 1000
      }
    },
    "severity": {
      "name": "Severity",
      "required": true,
      "type": "select",
      "options": ["Must", "Good", "Suggested"],
      "default": "Must",
      "description": "Importance level of the item"
    },
    "rule_reference": {
      "name": "Rule-Reference",
      "required": false,
      "type": "text",
      "description": "Reference to specific rule or standard",
      "validation": {
        "max_length": 100
      }
    },
    "additional_info": {
      "name": "AdditionalInfo",
      "required": false,
      "type": "text",
      "description": "Additional information or notes",
      "validation": {
        "max_length": 2000
      }
    }
  },
  "validation_rules": {
    "required_fields": ["SrNo", "Category", "SubCategory", "Description", "Severity"],
    "unique_fields": ["SrNo"],
    "max_rows_per_file": 1000,
    "min_rows_per_file": 1,
    "allowed_file_formats": [".xlsx", ".xls"],
    "max_file_size_mb": 50
  },
  "export_settings": {
    "markdown_format": "github",
    "include_metadata": true,
    "include_toc": false,
    "code_blocks": true,
    "tables": false
  }
}

{
  "column_mapping": {
    "checklist_id": "Checklist-ID",
    "sr_no": "SrNo",
    "category": "Category",
    "sub_category": "SubCategory",
    "description": "Description",
    "how_to_measure": "How to Measure",
    "severity": "Severity",
    "rule_reference": "Rule-Reference",
    "additional_info": "AdditionalInfo"
  },
  "validation": {
    "required_columns": [
      "SrNo",
      "Category",
      "SubCategory",
      "Description",
      "Severity"
    ],
    "optional_columns": [
      "Checklist-ID",
      "How to Measure",
      "Rule-Reference",
      "AdditionalInfo"
    ],
    "check_duplicates": true,
    "check_empty_rows": true,
    "min_rows": 1
  },
  "output": {
    "backup_enabled": true,
    "backup_suffix": ".backup",
    "encoding": "utf-8",
    "line_ending": "unix"
  },
  "logging": {
    "level": "INFO",
    "log_file": "conversion.log",
    "max_file_size": "10MB",
    "backup_count": 5
  },
  "item_type_detection": {
    "must_keywords": ["must", "required", "critical", "essential"],
    "good_keywords": ["good", "recommended", "should", "prefer"],
    "optional_keywords": ["optional", "nice to have", "consider", "may"]
  },
  "severity_mapping": {
    "must": "MUST",
    "required": "MUST", 
    "critical": "MUST",
    "essential": "MUST",
    "good": "GOOD",
    "recommended": "GOOD",
    "should": "GOOD",
    "prefer": "GOOD",
    "optional": "OPTIONAL",
    "nice to have": "OPTIONAL",
    "consider": "OPTIONAL",
    "may": "MAY"
  }
}

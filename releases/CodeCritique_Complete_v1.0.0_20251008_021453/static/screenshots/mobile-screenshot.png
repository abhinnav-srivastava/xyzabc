<!-- Placeholder mobile screenshot -->
<svg width="375" height="667" viewBox="0 0 375 667" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f8f9fa;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e9ecef;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background -->
  <rect width="375" height="667" fill="url(#bg)"/>
  
  <!-- Header -->
  <rect x="0" y="0" width="375" height="60" fill="#0d6efd"/>
  <text x="187" y="35" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle" fill="white">CodeCritique</text>
  
  <!-- Content area -->
  <rect x="20" y="80" width="335" height="500" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
  
  <!-- Mock content -->
  <text x="187" y="140" font-family="Arial, sans-serif" font-size="20" font-weight="bold" text-anchor="middle" fill="#212529">Mobile Review</text>
  <text x="187" y="170" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="#6c757d">Role-based code review on mobile</text>
  
  <!-- Mock buttons -->
  <rect x="50" y="220" width="275" height="40" fill="#0d6efd" rx="4"/>
  <text x="187" y="245" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">Start Review</text>
  
  <rect x="50" y="280" width="275" height="40" fill="#6c757d" rx="4"/>
  <text x="187" y="305" font-family="Arial, sans-serif" font-size="14" font-weight="bold" text-anchor="middle" fill="white">View Summary</text>
  
  <!-- Footer -->
  <text x="187" y="620" font-family="Arial, sans-serif" font-size="12" text-anchor="middle" fill="#6c757d">CodeCritique Mobile</text>
</svg>



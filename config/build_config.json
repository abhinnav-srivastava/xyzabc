{
  "build": {
    "app_name": "CodeReview",
    "version": "1.0.0",
    "description": "Professional code review tool with role-based, category-driven checklists",
    "license": "Apache-2.0"
  },
  "pyinstaller": {
    "console": true,
    "onefile": true,
    "upx": true,
    "clean": true,
    "noconfirm": true,
    "excludes": [
      "tkinter",
      "matplotlib",
      "numpy",
      "scipy",
      "pandas.tests",
      "pytest",
      "unittest"
    ],
    "hidden_imports": [
      "flask",
      "pandas",
      "reportlab",
      "openpyxl",
      "jinja2",
      "werkzeug",
      "markupsafe",
      "itsdangerous",
      "click",
      "blinker",
      "email_validator",
      "importlib_metadata",
      "zipp"
    ],
    "datas": [
      "config:config",
      "templates:templates",
      "static:static",
      "checklists:checklists",
      "services:services",
      "scripts:scripts"
    ]
  },
  "portable": {
    "include_files": [
      "README.md",
      "LICENSE",
      "requirements.txt"
    ],
    "create_startup_script": true,
    "create_readme": true,
    "create_zip": true
  }
}



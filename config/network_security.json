{
  "network_security": {
    "enabled": true,
    "block_external_connections": true,
    "allowed_domains": [],
    "blocked_domains": [
      "google.com",
      "facebook.com", 
      "twitter.com",
      "linkedin.com",
      "youtube.com",
      "amazon.com",
      "microsoft.com",
      "apple.com"
    ],
    "allowed_ips": [
      "127.0.0.1",
      "localhost",
      "::1"
    ],
    "blocked_ips": [],
    "allowed_ports": [5000],
    "blocked_ports": [],
    "firewall_rules": {
      "inbound": {
        "enabled": true,
        "default_action": "deny",
        "allowed_connections": [
          {
            "port": 5000,
            "protocol": "tcp",
            "source": "127.0.0.1",
            "description": "Local Flask app"
          }
        ]
      },
      "outbound": {
        "enabled": true,
        "default_action": "deny",
        "allowed_connections": [
          {
            "port": 80,
            "protocol": "tcp",
            "destination": "127.0.0.1",
            "description": "Local HTTP"
          },
          {
            "port": 443,
            "protocol": "tcp", 
            "destination": "127.0.0.1",
            "description": "Local HTTPS"
          }
        ]
      }
    },
    "dns_blocking": {
      "enabled": true,
      "blocked_domains": [
        "*.google.com",
        "*.facebook.com",
        "*.twitter.com",
        "*.linkedin.com",
        "*.youtube.com",
        "*.amazon.com",
        "*.microsoft.com",
        "*.apple.com"
      ],
      "allowed_domains": [
        "localhost",
        "127.0.0.1"
      ]
    },
    "proxy_settings": {
      "enabled": false,
      "proxy_host": "",
      "proxy_port": 0,
      "proxy_username": "",
      "proxy_password": ""
    },
    "ssl_verification": {
      "enabled": true,
      "verify_certificates": true,
      "allowed_certificates": []
    }
  },
  "application_security": {
    "cors": {
      "enabled": true,
      "allowed_origins": ["http://localhost:5000", "http://127.0.0.1:5000"],
      "allowed_methods": ["GET", "POST"],
      "allowed_headers": ["Content-Type", "Authorization"],
      "max_age": 3600
    },
    "csrf_protection": {
      "enabled": true,
      "token_length": 32,
      "token_expiry": 3600
    },
    "rate_limiting": {
      "enabled": true,
      "requests_per_minute": 60,
      "requests_per_hour": 1000,
      "block_duration": 300
    },
    "session_security": {
      "secure_cookies": false,
      "http_only_cookies": true,
      "same_site": "lax",
      "session_timeout": 3600
    }
  },
  "monitoring": {
    "enabled": true,
    "log_blocked_connections": true,
    "log_allowed_connections": false,
    "alert_on_suspicious_activity": true,
    "max_log_size": "100MB",
    "log_retention_days": 30
  }
}

{
  "name": "codereview",
  "version": "1.0.0",
  "description": "CodeReview - Code review checklist app",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "node scripts/build-electron-win.js",
    "pack:win": "electron-builder --win --dir",
    "dist:win": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.codereview.app",
    "productName": "CodeReview",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "app.py",
      "config/**/*",
      "checklists/**/*",
      "services/**/*",
      "templates/**/*",
      "static/**/*",
      "utils/**/*",
      "tools/**/*",
      "data",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/CodeReview.exe",
        "to": "backend/CodeReview.exe"
      }
    ],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "dir", "arch": ["x64"] }
      ],
      "icon": "static/icons/icon.ico"
    }
  }
}

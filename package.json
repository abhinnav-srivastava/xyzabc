{
  "name": "codereview",
  "version": "1.0.0",
  "description": "CodeReview - Code review checklist app",
  "main": "electron/main.js",
  "scripts": {
    "start": "npx electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "build:win": "node scripts/build-electron-win.js",
    "build:win:pyonly": "node scripts/build-electron-win.js --skip-electron",
    "pack:win": "electron-builder --win --dir",
    "dist:win": "electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "sharp-ico": "^0.1.5"
  },
  "build": {
    "appId": "com.codereview.app",
    "productName": "CodeReview",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "app.py",
      "config/**/*",
      "checklists/**/*",
      "services/**/*",
      "templates/**/*",
      "static/**/*",
      "utils/**/*",
      "tools/**/*",
      "data",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/CodeReview.exe",
        "to": "backend/CodeReview.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "static/icons/icon.ico"
    }
  }
}
